# ============================================
# Vibe Money Book — 環境變數配置
# ============================================
# 複製此檔案為 .env 後修改
# cp .env.example .env
#
# ⚠️ .env 含敏感資訊，嚴禁 commit！

# --------------------------------------------
# 基本設定
# --------------------------------------------
NODE_ENV=production
API_PORT=3000

# JWT 密鑰（正式環境請使用強隨機字串）
JWT_SECRET=your-jwt-secret-change-me

# 資料庫（SQLite）
DATABASE_URL=file:/app/data/dev.db

# CORS 允許的來源（留空則允許全部）
# CORS_ORIGIN=https://your-domain.com

# --------------------------------------------
# LLM 模型配置
# --------------------------------------------

# Gemini 模型（預設：gemini-3-flash-preview）
# 可選：gemini-3-flash-preview, gemini-2.5-flash, gemini-2.5-pro,
#       gemini-2.0-flash, gemini-3.1-flash-lite-preview
GEMINI_MODEL=gemini-3-flash-preview

# OpenAI 模型（預設：gpt-5.4-mini）
# 可選：gpt-5.4-mini, gpt-5.4, gpt-5.4-nano, gpt-5.4-pro, gpt-4.1, gpt-4.1-mini
OPENAI_MODEL=gpt-5.4-mini

# LLM 請求逾時（毫秒）
# Gemini 預設 30000ms，OpenAI 預設 10000ms
LLM_TIMEOUT_MS=30000

# --------------------------------------------
# 速率限制（每分鐘請求數）
# --------------------------------------------
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_API_PER_MIN=100
RATE_LIMIT_LLM_PER_MIN=20
